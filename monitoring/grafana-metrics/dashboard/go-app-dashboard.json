          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(orders_created_total{status=\"success\"}[5m]) / rate(orders_created_total[5m]) * 100",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "주문 생성 추이",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
